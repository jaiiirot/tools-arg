---
import ConsoleLayout from '../../layouts/ConsoleLayout.astro';
import { Sidebar } from '../../components/dashboard/Sidebar';
import { ServiceGrid } from '../../components/dashboard/ServiceGrid';
import { ProtectedRoute } from '../../components/auth/ProtectedRoute';
import { getAvailableServices } from '../../services/services.service';

const services = await getAvailableServices();
---

<ConsoleLayout title="Área de Cliente">
  <!-- El guardián bloqueará el renderizado si no hay sesión activa -->
  <ProtectedRoute client:only="react">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      
      <div class="lg:col-span-1">
        <Sidebar client:load />
      </div>

      <main class="lg:col-span-3">
        <ServiceGrid client:load initialServices={services} />
      </main>

    </div>
  </ProtectedRoute>
</ConsoleLayout>