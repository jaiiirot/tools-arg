---
import ConsoleLayout from '../../layouts/ConsoleLayout.astro';
import { ProtectedRoute } from '../../components/auth/ProtectedRoute';
import { AdminDashboard } from '../../components/admin/AdminDashboard.tsx';
---

<ConsoleLayout title="Root Access">
  <ProtectedRoute client:only="react">
    <div class="mb-6">
      <h1 class="text-3xl font-bold tracking-widest text-red-500">
        root@system<span class="text-console-white">:~#</span> <span class="animate-blink">_</span>
      </h1>
      <p class="text-xs text-console-gray mt-1">{">"} MODO ADMINISTRADOR ACTIVADO. PROCEDA CON PRECAUCIÓN.</p>
    </div>

    <!-- Panel de control interactivo -->
    <AdminDashboard client:load />
  </ProtectedRoute>
</ConsoleLayout>