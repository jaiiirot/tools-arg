---
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import { AuthTerminal } from '../components/auth/AuthTerminal';
import { Sidebar } from '../components/dashboard/Sidebar'; // Reutilizamos el panel de logs de la V2
---

<ConsoleLayout title="Portal de Acceso">
  <div class="min-h-[80vh] flex flex-col md:flex-row items-center justify-center gap-8">
    
    <!-- Lado Izquierdo: Terminal interactiva de Auth -->
    <main class="w-full md:w-1/2">
      <div class="mb-8 text-center md:text-left">
        <h1 class="text-4xl font-bold tracking-widest mb-2">
          <span class="text-console-white">tools</span>Arg<span class="text-console-green animate-blink">_</span>
        </h1>
        <p class="text-xs text-console-gray font-mono">
          > ACCESO RESTRINGIDO // SOLO DISTRIBUIDORES AUTORIZADOS
        </p>
      </div>
      
      <AuthTerminal client:load />
    </main>

    <!-- Lado Derecho: Monitor de Sistema (Reutilizado del dashboard para consistencia visual) -->
    <aside class="w-full md:w-1/3 hidden md:block opacity-70">
      <div class="border border-console-gray bg-[#1a1a19] p-4 h-96 flex flex-col">
        <h2 class="text-[10px] font-bold text-console-gray mb-2 uppercase">System_Logs // Boot Sequence</h2>
        <!-- Aquí podríamos aislar solo la parte de logs de la Sidebar, pero para el prototipo usamos un contenedor estático o un componente de logs dedicado -->
        <div class="flex-1 overflow-y-auto text-[10px] font-mono text-console-green space-y-2 pr-2" id="boot-logs">
          <p>> Inicializando protocolos de seguridad...</p>
          <p>> Cargando Firebase Auth (Capa Gratuita)...</p>
          <p>> Estado: <span class="text-console-white">ESPERANDO CREDENCIALES</span></p>
          <p class="animate-blink">_</p>
        </div>
      </div>
    </aside>

  </div>
</ConsoleLayout>